<?xml version="1.0"?>
<project name="ExtensionBuilder" default="extensions">
    <property name="lib.dir" value="lib" />
    <property name="build.dir" value="build" />
    <property name="classes.dir" value="${build.dir}/classes" />
    <property name="dist.dir" value="out" />

    <target name="clean">
        <delete dir="${build.dir}" />
        <delete dir="${dist.dir}" />
    </target>

    <target name="prepare">
        <mkdir dir="${classes.dir}" />
        <mkdir dir="${dist.dir}" />
    </target>

    <target name="compile" depends="prepare">
        <javac srcdir="src" destdir="${classes.dir}" includeantruntime="false">
            <classpath>
                <fileset dir="${lib.dir}">
                    <include name="**/*.jar" />
                </fileset>
            </classpath>
        </javac>
    </target>

    <target name="extensions" depends="compile">
        <jar destfile="${dist.dir}/extension.aix" basedir="${classes.dir}" />
        <echo message="Compilação concluída! Arquivo gerado em out/extension.aix" />
    </target>
</project>
