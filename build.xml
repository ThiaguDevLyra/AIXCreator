<?xml version="1.0" encoding="UTF-8"?>
<project name="ExtensionBuild" default="all">
    <property name="extension.name" value="com.lyra.extension.HelloExtension" />
    <target name="all" depends="compile" />
    <target name="compile">
        <mkdir dir="out" />
        <javac srcdir="src" destdir="out" includeantruntime="false" target="1.8" source="1.8">
            <classpath>
                <fileset dir="lib">
                    <include name="*.jar" />
                </fileset>
            </classpath>
        </javac>
    </target>
</project>