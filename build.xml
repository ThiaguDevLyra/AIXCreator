<?xml version="1.0" encoding="UTF-8"?>
<project name="LyraWebView" default="extensions">
    <property name="extension.pkg" value="com.lyra.webview" />
    <property name="extension.class" value="LyraWebView" />
    <property name="lib.dir" value="lib" />
    <property name="build.dir" value="build" />
    <property name="dist.dir" value="dist" />
    <property name="public.dir" value="public" />

    <target name="extensions">
        <mkdir dir="${build.dir}" />
        <mkdir dir="${dist.dir}" />
        <javac srcdir="src" destdir="${build.dir}" includeantruntime="false" target="1.8" source="1.8">
            <classpath>
                <fileset dir="${lib.dir}" includes="*.jar" />
            </classpath>
        </javac>
        <jar destfile="${dist.dir}/${extension.pkg}.aix">
            <fileset dir="${build.dir}" />
        </jar>
    </target>
</project>