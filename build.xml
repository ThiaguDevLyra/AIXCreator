<?xml version="1.0" encoding="UTF-8"?>
<project name="LyraWebView" default="all">
    <property name="extension.pkg" value="com.lyra.webview" />
    <property name="build.dir" location="build" />
    <property name="src.dir" location="src" />
    <property name="lib.dir" location="lib" />

    <target name="all" depends="compile, jar" />

    <target name="compile">
        <mkdir dir="${build.dir}/classes" />
        <javac srcdir="${src.dir}" destdir="${build.dir}/classes" source="1.8" target="1.8" includeantruntime="false">
            <classpath>
                <fileset dir="${lib.dir}">
                    <include name="*.jar" />
                </fileset>
            </classpath>
        </javac>
    </target>

    <target name="jar" depends="compile">
        <jar destfile="${build.dir}/${extension.pkg}.aix">
            <fileset dir="${build.dir}/classes" />
        </jar>
    </target>
</project>