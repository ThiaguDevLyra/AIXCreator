<?xml version="1.0" encoding="UTF-8"?>
<project name="ExampleExtension" default="all">
    <property name="extension.name" value="com.lyra.example.ExampleExtension" />
    <property name="lib.dir" value="lib" />
    <property name="src.dir" value="src" />
    <property name="build.dir" value="build" />
    <property name="dist.dir" value="dist" />

    <target name="init">
        <mkdir dir="${build.dir}" />
        <mkdir dir="${dist.dir}" />
    </target>

    <target name="compile" depends="init">
        <javac srcdir="${src.dir}" destdir="${build.dir}" target="1.8" source="1.8" debug="true">
            <classpath>
                <fileset dir="${lib.dir}">
                    <include name="**/*.jar" />
                </fileset>
            </classpath>
        </javac>
    </target>

    <target name="all" depends="compile">
        <jar destfile="${dist.dir}/${extension.name}.aix" basedir="${build.dir}" />
    </target>
</project>